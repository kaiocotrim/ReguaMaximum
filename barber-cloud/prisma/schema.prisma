generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  // Cliente faz agendamentos
  bookings Booking[]

  // Usuário pode trabalhar em várias barbearias
  barbers Barber[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Barbershop {
  id String @id @default(uuid())

  name        String
  address     String
  phones      String[]
  description String
  imageUrl    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  services BarbershopService[]
  barbers  Barber[]
  bookings Booking[]
}

model BarbershopService {
  id String @id @default(uuid())

  name        String
  description String
  imageUrl    String

  price Decimal @db.Decimal(10, 2)

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  bookings Booking[]
}

model Barber {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  // Qual usuário é o barbeiro
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Em qual barbearia ele trabalha
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  // Agendamentos do barbeiro
  bookings Booking[]
}

model Booking {
  id String @id @default(uuid())

  // Cliente
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Barbearia
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  // Serviço
  serviceId String
  service   BarbershopService @relation(fields: [serviceId], references: [id])

  // Barbeiro
  barberId String
  barber   Barber @relation(fields: [barberId], references: [id])

  // Data do agendamento
  date DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
