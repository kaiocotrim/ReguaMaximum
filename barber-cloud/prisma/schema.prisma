generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  BARBER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime? @map("email_verified")
  image         String?

  role          UserRole?

  resetPasswordToken  String?
  resetPasswordExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  barber Barber?
  client Client?
  bookings Booking[]
  favorites FavoriteBarbershop[]

  @@map("users")
}

model Client {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome   String?
  avatar String?
  cidade String?

  createdAt DateTime @default(now())
}

model Barber {
  id String @id @default(cuid())

  userId String @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome           String?
  avatar         String?
  bio            String?
  cidade         String?
  especialidades String[]

  barbershopId String?
  barbershop   Barbershop? @relation(fields: [barbershopId], references: [id])

  createdAt DateTime @default(now())
  bookings  Booking[]
}

model Barbershop {
  id          String   @id @default(uuid())
  name        String
  address     String
  phones      String[]
  description String
  imageUrl    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barbers     Barber[]
  services    BarbeshopService[]
  bookings    Booking[]
  favoritedBy FavoriteBarbershop[]
}

model BarbeshopService {
  id           String     @id @default(uuid())
  name         String
  description  String
  imageUrl     String
  price        Decimal    @db.Decimal(10, 2)

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  bookings Booking[]
}
model Booking {
  id           String   @id @default(uuid())

  userId       String
  user         User     @relation(fields: [userId], references: [id])

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  serviceId    String
  service      BarbeshopService @relation(fields: [serviceId], references: [id])

  barberId     String
  barber       Barber @relation(fields: [barberId], references: [id])

  date         DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FavoriteBarbershop {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, barbershopId])
}

model Account {
  id                String @id @default(cuid())
  userId            String @map("user_id")
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}